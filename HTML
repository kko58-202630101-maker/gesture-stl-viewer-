<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Camera Test</title>

<style>
body{
    background:#111;
    color:white;
    text-align:center;
    font-family:Arial;
}

video{
    width:500px;
    border:2px solid white;
}
</style>
</head>

<body>

<h1>웹캠 테스트</h1>

<video id="video" autoplay playsinline></video>

<script>

const video =
document.getElementById("video");

navigator.mediaDevices
.getUserMedia({video:true})
.then(stream=>{
 video.srcObject = stream;
})
.catch(err=>{
 alert(err.message);
});

</script>

</body>
</html>
